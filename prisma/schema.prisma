generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id        String   @id
  email     String   @unique
  name      String?
  currency  String   @default("USD")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  portfolios Portfolio[]
  watchlists Watchlist[]
  alerts     Alert[]

  @@map("profiles")
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  symbol    String
  shares    Float
  avgPrice  Float    @map("avg_price")
  currency  String   @default("USD")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portfolios")
}

model Watchlist {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  symbol      String
  targetPrice Float?   @map("target_price")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@map("watchlists")
}

model Alert {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  symbol      String
  condition   String
  price       Float
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  triggeredAt DateTime? @map("triggered_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

model MarketData {
  id            String   @id @default(cuid())
  symbol        String   @unique
  price         Float
  change        Float
  changePercent Float    @map("change_percent")
  volume        BigInt
  marketCap     BigInt?  @map("market_cap")
  peRatio       Float?   @map("pe_ratio")
  week52High    Float    @map("week52_high")
  week52Low     Float    @map("week52_low")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("market_data")
}
